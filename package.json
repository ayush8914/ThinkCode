{
  "name": "ThinkCode",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "logs:api": "kubectl logs -f -l app=judge-api -n thinkcode",
    "logs:worker": "kubectl logs -f -l app=judge-worker -n thinkcode",
    "logs:web": "kubectl logs -f -l app=web -n thinkcode",
    "docker:up": "docker-compose -f docker/postgres/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/postgres/docker-compose.yml down",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "cluster:delete": "kind delete cluster --name thinkcode-cluster"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "zod": "^4.3.6"
  }
}
