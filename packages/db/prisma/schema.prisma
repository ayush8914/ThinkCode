generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}



model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String?        
  name              String?
  role              Role           @default(USER)
  image             String?        
  provider          String?
  contestRating     Int            @default(800)
  maxContestRating  Int            @default(800)
  globalRanking     Int?       
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  submissions   Submission[]
  activities    UserActivity[]
  contestParticipants ContestParticipant[]
  ratingChanges       RatingChange[]
  
  @@map("users")
}

model Problem {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  description      String         @db.Text
  difficulty       Difficulty     @default(EASY)
  timeLimitMs      Int            @default(2000)
  memoryLimitKb    Int            @default(262144)

  //stats
  totalSubmissions Int            @default(0)
  acceptedSubmissions Int         @default(0)
  acceptedRate     Float          @default(0)

  isPublic         Boolean        @default(false)
  isConsumed       Boolean        @default(false)
  isDailyChallenge Int            @default(0) // 0 means not a daily challenge, 1 means it's a today's challenge, 2 means to keep history that it's a past daily challenge 
  
  rating           Int            @default(10)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  tags             ProblemTag[]
  testCases        TestCase[]
  submissions      Submission[]
  contestProblems  ContestProblem[]

  
  @@map("problems")
}

model TestCase {
  id          String   @id @default(cuid())
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  input       String   @db.Text
  output      String   @db.Text
  isSample    Boolean  @default(false)
  explanation String?  @db.Text
  orderIndex  Int      @default(0)
  
  @@map("test_cases")
}

model Tag {
  id       String        @id @default(cuid())
  name     String        @unique
  problems ProblemTag[]
  
  @@map("tags")
}

model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
  @@map("problem_tags")
}

model Submission {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  code        String    @db.Text
  language    Language
  status      Status    @default(PENDING)
  
  executionTimeMs Int?
  memoryUsedKb    Int?
  errorMessage    String?  @db.Text
  failedTestCaseIndex Int?
  
  createdAt   DateTime  @default(now())
  judgedAt    DateTime?

  contestId   String?   // ADD THIS
  contest     Contest?  @relation(fields: [contestId], references: [id], onDelete: SetNull)
  
  
  @@index([userId, problemId])
  @@index([status])
  @@index([createdAt])
  @@map("submissions")
}


model UserActivity {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime  @map("activity_date")
  
  submissions Int       @default(0)
  accepted    Int       @default(0)
  wrongAnswer Int       @default(0)
  timeLimit   Int       @default(0)
  runtimeError Int      @default(0)
  compilationError Int  @default(0)
  
  @@unique([userId, date])
  @@map("user_activities")
}


model Contest {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?       @db.Text
  
  contestName ContestName   // STARTERS, WEEKLY, LONG_WEEK
  contestType ContestType   // RATED, UNRATED
  
  startTime   DateTime
  endTime     DateTime
  registrationDeadline DateTime?
  
  isPublic    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  divisions   ContestDivision[]
  problems    ContestProblem[]
  participants ContestParticipant[]
  ratingChanges RatingChange[]
  submissions  Submission[]
  
  @@map("contests")
}

model ContestDivision {
  id          String    @id @default(cuid())
  contestId   String
  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  division    Division
  
  @@unique([contestId, division])
  @@map("contest_divisions")
}

model ContestProblem {
  id          String    @id @default(cuid())
  contestId   String
  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  orderIndex  Int       @default(0) 

  visibleToDivisions Division[]
  
  @@map("contest_problems")
}

model ContestParticipant {
  id          String    @id @default(cuid())
  contestId   String
  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  division    Division  
  
  registeredAt DateTime @default(now())
  
  score       Int       @default(0)
  rank        Int?
  solvedCount Int       @default(0)
  penalty     Int       @default(0)  
  
  problemStatuses Json?  // [{ problemId, attempts, solved, solveTime, score }]
  
  @@unique([contestId, userId])
  @@map("contest_participants")
}

model RatingChange {
  id          String    @id @default(cuid())
  contestId   String
  contest     Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  division    Division
  
  oldRating   Int
  newRating   Int
  change      Int
  rank        Int
  
  createdAt   DateTime  @default(now())
  
  @@unique([contestId, userId])
  @@map("rating_changes")
}

enum Division {
  DIV1  // Rating >= 2000
  DIV2  // Rating 1600-1999
  DIV3  // Rating 1400-1599
  DIV4  // Rating <= 1399
}

enum Role {
  USER
  ADMIN
  PROBLEM_SETTER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  PYTHON
  CPP
  C
  JS
}

enum Status {
  PENDING
  PROCESSING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  INTERNAL_ERROR
}

enum ContestName {
  STARTERS   //on every Wednesday
  WEEKLY     //on every Sunday
  LONG_WEEK    //on every Saturday - Monday
}

enum ContestType {
  RATED
  UNRATED
}