{
  "name": "@repo/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
