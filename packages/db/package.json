    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "prisma": "^7.7.0",
    "typescript": "^5.9.2"
  }
}
